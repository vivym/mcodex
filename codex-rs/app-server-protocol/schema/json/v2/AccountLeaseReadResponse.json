{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AccountStartupAvailability": {
      "enum": [
        "available",
        "suppressed",
        "multiplePoolsRequireDefault",
        "invalidExplicitDefault",
        "unavailable"
      ],
      "type": "string"
    },
    "AccountStartupCandidatePool": {
      "properties": {
        "displayName": {
          "type": [
            "string",
            "null"
          ]
        },
        "poolId": {
          "type": "string"
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "displayName",
        "poolId",
        "status"
      ],
      "type": "object"
    },
    "AccountStartupResolutionIssue": {
      "properties": {
        "candidatePoolCount": {
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "candidatePools": {
          "items": {
            "$ref": "#/definitions/AccountStartupCandidatePool"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "poolId": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "$ref": "#/definitions/AccountStartupResolutionIssueSource"
        },
        "type": {
          "$ref": "#/definitions/AccountStartupResolutionIssueType"
        }
      },
      "required": [
        "candidatePoolCount",
        "candidatePools",
        "message",
        "poolId",
        "source",
        "type"
      ],
      "type": "object"
    },
    "AccountStartupResolutionIssueSource": {
      "enum": [
        "override",
        "configDefault",
        "persistedSelection",
        "none"
      ],
      "type": "string"
    },
    "AccountStartupResolutionIssueType": {
      "enum": [
        "multiplePoolsRequireDefault",
        "overridePoolUnavailable",
        "configDefaultPoolUnavailable",
        "persistedDefaultPoolUnavailable"
      ],
      "type": "string"
    },
    "AccountStartupSnapshot": {
      "properties": {
        "configuredDefaultPoolId": {
          "type": [
            "string",
            "null"
          ]
        },
        "effectivePoolId": {
          "type": [
            "string",
            "null"
          ]
        },
        "effectivePoolResolutionSource": {
          "type": "string"
        },
        "persistedDefaultPoolId": {
          "type": [
            "string",
            "null"
          ]
        },
        "selectionEligibility": {
          "type": "string"
        },
        "startupAvailability": {
          "$ref": "#/definitions/AccountStartupAvailability"
        },
        "startupResolutionIssue": {
          "anyOf": [
            {
              "$ref": "#/definitions/AccountStartupResolutionIssue"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "configuredDefaultPoolId",
        "effectivePoolId",
        "effectivePoolResolutionSource",
        "persistedDefaultPoolId",
        "selectionEligibility",
        "startupAvailability",
        "startupResolutionIssue"
      ],
      "type": "object"
    }
  },
  "properties": {
    "accountId": {
      "type": [
        "string",
        "null"
      ]
    },
    "active": {
      "type": "boolean"
    },
    "configuredDefaultPoolId": {
      "type": [
        "string",
        "null"
      ]
    },
    "effectivePoolResolutionSource": {
      "type": [
        "string",
        "null"
      ]
    },
    "healthState": {
      "type": [
        "string",
        "null"
      ]
    },
    "lastRemoteContextResetTurnId": {
      "type": [
        "string",
        "null"
      ]
    },
    "leaseAcquiredAt": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "leaseEpoch": {
      "format": "uint64",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    },
    "leaseId": {
      "type": [
        "string",
        "null"
      ]
    },
    "minSwitchIntervalSecs": {
      "format": "uint64",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    },
    "nextEligibleAt": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "persistedDefaultPoolId": {
      "type": [
        "string",
        "null"
      ]
    },
    "poolId": {
      "type": [
        "string",
        "null"
      ]
    },
    "proactiveSwitchAllowedAt": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "proactiveSwitchPending": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "proactiveSwitchSuppressed": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "startup": {
      "$ref": "#/definitions/AccountStartupSnapshot"
    },
    "suppressed": {
      "type": "boolean"
    },
    "suppressionReason": {
      "type": [
        "string",
        "null"
      ]
    },
    "switchReason": {
      "type": [
        "string",
        "null"
      ]
    },
    "transportResetGeneration": {
      "format": "uint64",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    }
  },
  "required": [
    "active",
    "startup",
    "suppressed"
  ],
  "title": "AccountLeaseReadResponse",
  "type": "object"
}